{
  "root": true,
  "env": {
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2019
  },
  "extends": "eslint:recommended",
  "ignorePatterns": [
    "/dist/",
    "/app-components/",
    "/vendor/",
    "/_site/",
    "*.min.js",
    "*.mjs",
    "app-components.js",
    "build-pages.js",
    "generateFonts.js",
    "instant-page.min.js",
    "protractor.conf.js",
    "scroll-to-top.js",
    "theme-toggle.js"
  ],
  "rules": {
    "no-return-await": "error",
    "no-unused-vars": "off",
    "no-useless-escape": "off",
    "object-curly-spacing": ["error", "always"]
  }
}
